# scheme-writer configuration
#
# 复制本文件为 ~/.claude/scheme-writer/.env 并填入实际值；
# 或直接运行 `python scripts/init.py`（终端向导）/ 在对话里说"配置 scheme-writer"
# 由 Claude 在对话内用 `--add-source` 逐步引导配置。
#
# 多来源模型：一个「来源」= 一组 (name, url, api_key)，对应一个 WeKnora 空间或实例。
# - 同实例多空间 → 多条来源、相同 url、不同 api_key
# - 多实例       → 多条来源、不同 url、不同 api_key
#
# 老用户（旧单实例 KNOWLEDGE_BASE_URL/KEY 形态）无需手改：首次跑任意 init.py 子命令
# 会自动迁移为下方 SOURCES 形态（合成 default 来源 + 别名加 default/ 前缀 + 备份 .env.bak）。

# 来源清单（必填）：JSON 数组，每条 {name, url, api_key}（name 不能含 "/"）
SOURCES=[{"name":"运维空间1","url":"http://192.168.30.236/api/v1","api_key":"sk-xxx1"},{"name":"安全部","url":"http://10.5.20.8/api/v1","api_key":"sk-xxx2"}]

# 默认来源（可选）：用户未指定 --source 时使用；仅一个来源时可省略（隐式选中）
DEFAULT_SOURCE=运维空间1

# 别名（可选）：键为「来源/库名」限定名，值为 kb_id。
# 由 `python scripts/init.py --set-aliases '{...}'` 维护；手填也行。格式必须是合法 JSON。
# 不同来源里同名的 kb_id 靠来源前缀区分（不会冲突）。
KB_ALIASES={"运维空间1/技术规范库":"kb-001","运维空间1/方案库":"kb-002","安全部/漏洞库":"kb-001"}

# 默认检索/上传库（可选）：值用限定名「来源/库名」或裸 kb_id
DEFAULT_RETRIEVE_KB=运维空间1/技术规范库
DEFAULT_UPLOAD_KB=运维空间1/方案库

# ──────────────────────────────────────────────────────────────────────────
# 以下旧键仅供首跑迁移识别，迁移后不再被直接读取（保留在 .env 作为回滚线索）：
#   KNOWLEDGE_BASE_URL / KNOWLEDGE_BASE_API_KEY
# 新增来源一律用 `python scripts/init.py --add-source NAME URL KEY`。
