# scheme-writer configuration
# 复制本文件为 ~/.claude/scheme-writer/.env 并填入实际值
# 或直接运行 `python scripts/init.py` 由向导自动写入
# （首次使用 Claude 会在对话内自动引导配置，无需手动跑）

# 知识库（WeKnora）API 地址
KNOWLEDGE_BASE_URL=http://192.168.30.236/api/v1

# API Key（从服务端获取；切勿提交到 git）
KNOWLEDGE_BASE_API_KEY=sk-your-key-here

# 可选：用户未指定知识库时使用的默认值
DEFAULT_RETRIEVE_KB=
DEFAULT_UPLOAD_KB=

# 可选：口语化名称 → kb_id 的 JSON 映射。
# 由 `python scripts/init.py --set-aliases '{...}'` 维护；手填也行。
# 格式必须是合法 JSON，键值都是字符串。
KB_ALIASES={"技术规范库":"kb_id_001","方案库":"kb_id_002"}
