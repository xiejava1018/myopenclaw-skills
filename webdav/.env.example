# WebDAV 服务器配置
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# WebDAV 服务器地址（必填）
# 格式: https://your-nas-server.com/webdav 或 http://192.168.x.x:port/webdav
WEBDAV_SERVER=https://your-nas-server.com/webdav

# 认证信息（必填）
WEBDAV_USERNAME=your_username
WEBDAV_PASSWORD=your_password

# SSL 证书验证（可选，默认 true）
# 自签名证书的环境可设为 false
WEBDAV_SSL_VERIFY=true
