# image-upload 配置（复制为 .env 后填实际值）
# skill 完全自包含，不依赖 PicGo 运行时。可用 `python3 main.py init` 从 PicGo 一次性导入七牛配置。

DEFAULT_BACKEND=qiniu

# —— 七牛云（用 qiniu 后端必填）——
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=https://image2.ishareread.com
# 区域: z0华东 z1华北 z2华南 na0北美 as0东南亚
QINIU_AREA=z0
# 上传路径前缀
QINIU_PATH=blog

# —— GitHub（用 github 后端必填）——
# classic PAT(repo 权限) 或 fine-grained(contents:write)
GH_TOKEN=
GH_OWNER=xiejava1018
GH_REPO=image-bed
GH_BRANCH=main
GH_PATH=blog
# 留空 = https://raw.githubusercontent.com/{owner}/{repo}/{branch}
# 填写则用自定义域名（如 Cloudflare Worker 反代 raw）
GH_DOMAIN=
